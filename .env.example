# Hook environment variables.
# Once the V4 hook contract is deployed, addresses + RPC config go here.
# The umbrella server reads them at boot from server/.env.

# X Layer RPC + deployer (shared with the umbrella server)
X_LAYER_RPC_URL=https://rpc.xlayer.tech
DEPLOYER_PRIVATE_KEY=         # for hardhat / deploy scripts — NEVER commit

# Deployed contract addresses (filled after first deploy)
HOOK_V4_ADDRESS=
HOOK_POOL_MANAGER_ADDRESS=
