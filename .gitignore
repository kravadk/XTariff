# Mirror-local gitignore for kravadk/XTariff. The umbrella .gitignore covers the
# monorepo; this one runs when the mirror is cloned standalone.

node_modules
dist
.vite
.DS_Store
*.log
*.local

# env / secrets
.env
.env.local

# Hardhat / Foundry build output (when the V4 hook lands)
contracts/artifacts-hh/
contracts/cache-hh/
contracts/artifacts/
contracts/out/
contracts/cache/

# Foundry forge install — re-install via `forge install` instead of committing
contracts/lib/
contracts/broadcast/

# TypeScript build info
*.tsbuildinfo
