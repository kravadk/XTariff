# Hook environment variables (server-side slice).
# The umbrella server reads them at boot from server/.env. This file documents
# the Hook-specific subset; see ../../server/.env.example for the full set.

# --- X Layer RPC + deployer ---
X_LAYER_RPC_URL=https://rpc.xlayer.tech
DEPLOYER_PRIVATE_KEY=                  # for forge script + fanScoreSync — NEVER commit

# --- Uniswap V4 mainnet addresses on X Layer (chain 196) ---
# Verified 2026-05-23 via https://developers.uniswap.org/contracts/v4/deployments
POOL_MANAGER=0x360e68faccca8ca495c1b759fd9eee466db9fb32
UNIVERSAL_ROUTER=0x8b844f885672f333bc0042cb669255f93a4c1e6b
POSITION_MANAGER=0xcf1eafc6928dc385a342e7c6491d371d2871458b
STATE_VIEW=0x76fd297e2d437cd7f76d50f01afe6160f86e9990
PERMIT2=0x000000000022D473030F116dDEE9F6B43aC78BA3

# --- X Cup contracts FanFeeHook reads from (existing on X Layer mainnet) ---
FAN_PASS_SBT=                          # apps/xcup deploy — see docs/xcup/

# --- Tokens for the test pool ---
USDC_TOKEN=0x74b7F16337b8972027F6196A17a631aC6dE26d22
USDT_TOKEN=0x1E4a5963aBFD975d8c9021ce480b42188849D41d
# For InitTestPool.s.sol — must be sorted (token0 < token1)
POOL_TOKEN0=0x1E4a5963aBFD975d8c9021ce480b42188849D41d   # USDT (lower address)
POOL_TOKEN1=0x74b7F16337b8972027F6196A17a631aC6dE26d22   # USDC

# --- Operator (server EOA that writes scores + settles pot) ---
OPERATOR=                              # same as AGENTIC_WALLET_ADDRESS by default

# --- Deployed Hook contracts (filled by DeployFanFeeHook.s.sol output) ---
HOOK_FAN_FEE_HOOK=
HOOK_FAN_SCORE_REGISTRY=
HOOK_CUP_SIDE_POT=
HOOK_POOL_ID=                          # poolId from InitTestPool — for UI deep-links

# --- Sync feature flags (default off so dev never burns gas) ---
HOOK_SYNC_ENABLED=false
HOOK_SYNC_INTERVAL_MS=                 # default 604800000 (1 week)
